<controls:FancyWindow xmlns="https://spacestation14.io"
                           xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                           Title="Mass Cloak Console"
                           MinSize="200 200">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True">
        <GridContainer Margin="4 0 0 0" Columns="2">
            <Label Name="MassCloakLabel" Text="Mass Cloak" HorizontalExpand="True" StyleClasses="StatusFieldTitle" />
            <BoxContainer Orientation="Horizontal" MinWidth="120">
                <Button Name="MassCloakOnButton" Text="Enable" StyleClasses="OpenRight" />
                <Button Name="MassCloakOffButton" Text="Disable" StyleClasses="OpenLeft" />
            </BoxContainer>
            <Label Text="Range (20-500)" HorizontalExpand="True"/>
            <Slider Name="MassCloakRangeSlider" MinValue="20" MaxValue="500" Value="20" HorizontalExpand="True" />
            <Label Name="MassCloakRangeValue" Text="20" HorizontalAlignment="Center" />
        </GridContainer>
    </BoxContainer>
</controls:FancyWindow>