<Control xmlns="https://spacestation14.io"
         xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
         VerticalExpand="False">
    <PanelContainer StyleClasses="ServerInfoBackground">
        <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="10">
            <Label Text="ПОДДЕРЖКА ПРОЕКТА" StyleClasses="LabelHeading" HorizontalAlignment="Center" />
            
            <TabContainer Name="DonationTabs" MinHeight="260">
                <BoxContainer Name="TabInfo" Orientation="Vertical" VerticalExpand="True" Margin="5" SeparationOverride="5">
                    <ScrollContainer VerticalExpand="True">
                        <RichTextLabel Name="InfoText" />
                    </ScrollContainer>
                </BoxContainer>

                <BoxContainer Name="TabLevels" Orientation="Vertical" VerticalExpand="True" Margin="5" Visible="False" SeparationOverride="10">
                    <ScrollContainer VerticalExpand="True">
                        <RichTextLabel Name="LevelsText" />
                    </ScrollContainer>
                    <Button Name="BuyButtonLevels" Text="Поддержать проект" StyleClasses="NovaLobbyButton" Margin="0 5 0 0" />
                </BoxContainer>

                <BoxContainer Name="TabDiscord" Orientation="Vertical" VerticalExpand="True" Margin="5" Visible="False" SeparationOverride="10">
                    <ScrollContainer VerticalExpand="True">
                        <RichTextLabel Name="DiscordText" />
                    </ScrollContainer>
                    
                    <BoxContainer Orientation="Vertical" VerticalAlignment="Bottom" SeparationOverride="8">
                        <controls:HighDivider />
                        
                        <BoxContainer Name="DiscordUnlinkedState" Orientation="Vertical" SeparationOverride="10" Visible="False">
                            <TextureRect Name="DiscordQr" Stretch="KeepCentered" MinSize="140 140" HorizontalAlignment="Center" />
                            <Button Name="DiscordAuthButton" Text="Привязать Discord" StyleClasses="NovaLobbyButton" />
                        </BoxContainer>

                        <BoxContainer Name="DiscordLinkedState" Orientation="Vertical" SeparationOverride="5" Visible="False" HorizontalAlignment="Center">
                            <RichTextLabel Name="DiscordStatusLabel" />
                            <Label Name="DiscordUserLabel" Text="Загрузка..." FontColorOverride="Cyan" HorizontalAlignment="Center" />
                        </BoxContainer>

                        <Button Name="RefreshStatusButton" Text="Обновить статус" HorizontalAlignment="Center" />
                    </BoxContainer>
                </BoxContainer>
            </TabContainer>
        </BoxContainer>
    </PanelContainer>
</Control>